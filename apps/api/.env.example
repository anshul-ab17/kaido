DATABASE_URL="postgresql://postgres:password@127.0.0.1:5433/kaido?schema=public"
REDIS_URL="redis://localhost:6379"
NATS_URL="nats://localhost:4222"
JWT_SECRET="change-this-to-a-random-64-char-secret-at-least-32-chars"
ROUTING_ENGINE_URL="http://localhost:5000"
# Default devnet — set mainnet-beta + mainnet Helius when going to production
SOLANA_CLUSTER="devnet"
# Optional: override RPC (otherwise Helius or public cluster default is used)
# SOLANA_RPC_URL="https://api.devnet.solana.com"
HELIUS_API_KEY=
BIRDEYE_API_KEY=
ANTHROPIC_API_KEY=
# Jupiter Prediction API — get key at https://portal.jup.ag
# Without this, events page falls back to Polymarket Gamma API (read-only, no trading)
JUPITER_API_KEY=
PORT=4000
NODE_ENV=development
