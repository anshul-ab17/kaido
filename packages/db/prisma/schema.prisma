generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lastLogin     DateTime?
  referralCode  String?        @unique
  riskProfile   String?
  aiPreferences Json?
  settings      Json?
  featureFlags  Json?
  identities    AuthIdentity[]
  orders        Order[]
  trades        Trade[]

  @@map("users")
}

model AuthIdentity {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  type      String
  provider  String
  address   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([type, address])
  @@map("auth_identities")
}

model Market {
  id         String  @id @default(cuid())
  symbol     String  @unique
  baseToken  String
  quoteToken String
  type       String  @default("spot")
  active     Boolean @default(true)
  orders     Order[]
  trades     Trade[]

  @@map("markets")
}

model Order {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  marketId  String
  side      String
  type      String
  price     Float?
  size      Float
  filled    Float    @default(0)
  status    String   @default("open")
  user      User     @relation(fields: [userId], references: [id])
  market    Market   @relation(fields: [marketId], references: [id])

  @@map("orders")
}

model Trade {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  marketId  String
  side      String
  price     Float
  size      Float
  fee       Float
  signature String   @unique
  user      User     @relation(fields: [userId], references: [id])
  market    Market   @relation(fields: [marketId], references: [id])

  @@map("trades")
}

model Event {
  id              String          @id
  title           String
  description     String
  category        String
  status          String          @default("open")
  resolutionDate  BigInt
  qYes            Float           @default(0)
  qNo             Float           @default(0)
  volume          Float           @default(0)
  liquidity       Float           @default(1000)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  positions       EventPosition[]
  activity        EventActivity[]

  @@map("events")
}

model EventPosition {
  id        String   @id @default(cuid())
  eventId   String
  wallet    String
  yesShares Float    @default(0)
  noShares  Float    @default(0)
  yesCost   Float    @default(0)
  noCost    Float    @default(0)
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, wallet])
  @@map("event_positions")
}

model EventActivity {
  id        String   @id @default(cuid())
  eventId   String
  wallet    String
  side      String
  amount    Float
  shares    Float
  price     Float
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_activity")
}

model TpSlOrder {
  id          String   @id
  wallet      String
  market      String
  side        String
  size        Float
  entryPrice  Float
  tpPrice     Float?
  slPrice     Float?
  leverage    Float    @default(1)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([wallet])
  @@index([status])
  @@map("tpsl_orders")
}
